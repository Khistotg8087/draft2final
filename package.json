{
  "name": "draft2final",
  "version": "1.0.4",
  "description": "Professional manuscript and screenplay compiler. Turn Markdown into publication-grade PDFs.",
  "keywords": [
    "typesetting",
    "markdown",
    "pdf",
    "screenwriting",
    "scriptwriting",
    "manuscript",
    "novel",
    "book",
    "fountain",
    "typesetter",
    "academic",
    "literature",
    "publishing",
    "formatting"
  ],
  "author": "cosmiciron",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cosmiciron/draft2final.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "draft2final": "dist/cli.js"
  },
  "files": [
    "dist/**/*",
    "themes/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "dev": "tsx src/cli.ts",
    "profile:document": "tsx scripts/profile-document.ts",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@vmprint/context-pdf": "*",
    "@vmprint/engine": "*",
    "@vmprint/local-fonts": "*",
    "@vmprint/mkd-academic": "*",
    "@vmprint/mkd-literature": "*",
    "@vmprint/mkd-manuscript": "*",
    "@vmprint/mkd-mkd": "*",
    "@vmprint/mkd-screenplay": "*"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "@vmprint/contracts": "*",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  }
}
